# ── Registry ──────────────────────────────────────────────────────────────────
registry=https://registry.npmjs.org/
strict-ssl=true

# ── Lockfile ──────────────────────────────────────────────────────────────────
lockfile=true
# Uncomment in CI to abort if lockfile is stale:
# frozen-lockfile=true

# ── Security: vulnerability threshold ─────────────────────────────────────────
audit-level=moderate
